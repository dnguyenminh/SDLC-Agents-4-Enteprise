# SA4E-44 Environment Variables
# Copy to .env and fill in values

# --- Server ---
NODE_ENV=development
PORT=48721

# --- Database ---
DATABASE_ADAPTER=postgresql
DATABASE_URL=postgresql://sa4e_user:sa4e_local_dev_password@localhost:5432/sa4e_db

# --- Task Worker (Part 1) ---
TASK_WORKER_ENABLED=true
TASK_WORKER_POLL_INTERVAL_MS=5000
TASK_WORKER_MAX_RETRIES=3
TASK_WORKER_BACKOFF_BASE_MS=1000
TASK_WORKER_MAX_CONCURRENT=1
TASK_WORKER_DEAD_LETTER_ENABLED=true

# --- Code Intelligence (Part 2) ---
CODE_INTEL_ENABLED=true
CODE_INTEL_MAX_BATCH_SIZE=100
CODE_INTEL_UPLOAD_TIMEOUT_MS=30000
CODE_INTEL_VECTOR_ENABLED=false

# --- ONNX Runtime (optional --- for embeddings) ---
ONNX_RUNTIME_URL=http://localhost:8080
ONNX_MODEL_PATH=./models/all-MiniLM-L6-v2

# --- Security ---
API_KEY=
API_KEY_REQUIRED=false

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=pretty
