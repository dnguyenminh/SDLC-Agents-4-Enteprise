# SA4E-44 Test Environment Variables
NODE_ENV=test
PORT=48722

DATABASE_ADAPTER=postgresql
DATABASE_URL=postgresql://sa4e_user:sa4e_test_password@localhost:5433/sa4e_db_test

TASK_WORKER_ENABLED=true
TASK_WORKER_POLL_INTERVAL_MS=100
TASK_WORKER_MAX_RETRIES=2
TASK_WORKER_BACKOFF_BASE_MS=50
TASK_WORKER_MAX_CONCURRENT=1
TASK_WORKER_DEAD_LETTER_ENABLED=true

CODE_INTEL_ENABLED=true
CODE_INTEL_MAX_BATCH_SIZE=100
CODE_INTEL_UPLOAD_TIMEOUT_MS=5000
CODE_INTEL_VECTOR_ENABLED=false

API_KEY=test-api-key-sa4e-44
API_KEY_REQUIRED=true

LOG_LEVEL=warn
LOG_FORMAT=json
