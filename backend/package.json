{
  "name": "sdlc-agent-4-enterprise-server",
  "version": "1.9.1",
  "description": "Code Intelligence MCP Server — multi-agent SDLC pipeline with semantic memory, code graph, and draw.io integration",
  "main": "dist/index.js",
  "bin": {
    "sdlc-agent-4-enterprise-server": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch --ignore '.code-intel/**' src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs');const path=require('path');function cp(s,d){if(!fs.existsSync(d))fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s)){const sp=path.join(s,f),dp=path.join(d,f);fs.statSync(sp).isDirectory()?cp(sp,dp):fs.copyFileSync(sp,dp);}}cp('src/viewer','dist/viewer');\"",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e-api": "vitest run --config vitest.e2e.config.ts",
    "test:e2e-ui": "npx playwright test"
  },
  "keywords": [
    "mcp",
    "code-intelligence",
    "sdlc",
    "agents",
    "memory",
    "knowledge-base",
    "draw.io"
  ],
  "author": "SA4E Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnguyenminh/SDLC-Agents-4-Enteprise.git"
  },
  "engines": {
    "node": ">=18.14.1"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/pg": "^8.20.0",
    "@xenova/transformers": "^2.0.1",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^5.0.0",
    "hono": "^4.0.0",
    "onnxruntime-node": "^1.18.0",
    "pg": "^8.22.0",
    "pino": "^9.2.0",
    "web-tree-sitter": "^0.26.9",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "fast-check": "^4.9.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  },
  "directories": {
    "test": "tests"
  },
  "types": "./dist/index.d.ts",
  "bugs": {
    "url": "https://github.com/dnguyenminh/SDLC-Agents-4-Enteprise/issues"
  },
  "homepage": "https://github.com/dnguyenminh/SDLC-Agents-4-Enteprise#readme"
}
