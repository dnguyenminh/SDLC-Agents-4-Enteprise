{
  "name": "sdlc-agents-4-enterprise",
  "displayName": "SDLC Agents 4 Enterprise",
  "description": "Multi-agent SDLC pipeline for enterprise — 9 AI agents (SM, BA, TA, SA, QA, DEV, DevOps, Security, UI) orchestrated via MCP",
  "version": "1.0.0",
  "publisher": "dnguyenminh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dnguyenminh/SDLC-Agents-4-Enteprise"
  },
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "kiro",
    "sdlc",
    "agents",
    "multi-agent",
    "BA",
    "QA",
    "DevOps",
    "scrum",
    "mcp"
  ],
  "activationEvents": [
    "onView:kiroSdlcTree",
    "onView:kiroChatPanel",
    "onCommand:kiroSdlc.injectAll",
    "onCommand:kiroSdlc.status"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "kiroSdlc.injectAll",
        "title": "Kiro SDLC: Inject All Agents",
        "icon": "$(cloud-download)"
      },
      {
        "command": "kiroSdlc.injectSelective",
        "title": "Kiro SDLC: Inject (Select Components)"
      },
      {
        "command": "kiroSdlc.update",
        "title": "Kiro SDLC: Update Agents"
      },
      {
        "command": "kiroSdlc.status",
        "title": "Kiro SDLC: Show Status",
        "icon": "$(info)"
      },
      {
        "command": "kiroSdlc.openKbGraph",
        "title": "Kiro SDLC: Open KB Graph"
      },
      {
        "command": "kiroSdlc.openKbDashboard",
        "title": "Kiro SDLC: Open KB Dashboard"
      },
      {
        "command": "kiroSdlc.openKbTags",
        "title": "Kiro SDLC: Open KB Tags"
      },
      {
        "command": "kiroSdlc.openKbQuality",
        "title": "Kiro SDLC: Open KB Quality"
      },
      {
        "command": "kiroSdlc.openKbAnalytics",
        "title": "Kiro SDLC: Open KB Analytics"
      },
      {
        "command": "kiroSdlc.openWorkflowGraph",
        "title": "Kiro SDLC: Open Workflow Graph"
      },
      {
        "command": "kiroSdlc.symbolSearch",
        "title": "Kiro SDLC: Symbol Search"
      },
      {
        "command": "kiroSdlc.openSecurityPanel",
        "title": "Kiro SDLC: Security Panel"
      },
      {
        "command": "kiroSdlc.impactAnalysis",
        "title": "Kiro SDLC: Impact Analysis"
      },
      {
        "command": "kiroSdlc.getAIContext",
        "title": "Kiro SDLC: Get AI Context for Symbol"
      },
      {
        "command": "kiroSdlc.getEditContext",
        "title": "Kiro SDLC: Get Edit Context for Symbol"
      },
      {
        "command": "kiroSdlc.openSettings",
        "title": "Kiro SDLC: Settings",
        "icon": "$(gear)"
      },
      {
        "command": "kiroSdlc.openKbBrowser",
        "title": "Kiro SDLC: Open KB in Browser"
      },
      {
        "command": "kiroSdlc.login",
        "title": "Kiro SDLC: Login to Backend"
      },
      {
        "command": "kiroSdlc.logout",
        "title": "Kiro SDLC: Logout"
      },
      {
        "command": "kiroSdlc.reconnect",
        "title": "Kiro SDLC: Reconnect to Backend"
      },
      {
        "command": "kiroSdlc.disconnect",
        "title": "Kiro SDLC: Disconnect"
      },
      {
        "command": "kiroSdlc.indexDocuments",
        "title": "Kiro SDLC: Index Documents"
      },
      {
        "command": "kiroSdlc.indexSource",
        "title": "Kiro SDLC: Index Source Code"
      },
      {
        "command": "kiroSdlc.syncWorkspace",
        "title": "Kiro SDLC: Sync Workspace"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kiroSdlc",
          "title": "Kiro SDLC",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "kiroSdlc": [
        {
          "id": "kiroSdlcTree",
          "name": "SDLC Agents"
        },
        {
          "id": "kiroChatPanel",
          "name": "Chat Panel",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Kiro SDLC Agents",
      "properties": {
        "kiroSdlc.backend.url": {
          "type": "string",
          "default": "http://127.0.0.1:48721",
          "description": "Remote Kiro backend server URL"
        },
        "kiroSdlc.backend.ssoEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable SSO/PKCE authentication"
        },
        "kiroSdlc.backend.ssoProviderUrl": {
          "type": "string",
          "default": "",
          "description": "OAuth2 SSO provider URL for PKCE flow"
        },
        "kiroSdlc.backend.toolCallTimeout": {
          "type": "number",
          "default": 300000,
          "description": "Timeout for MCP tool calls (ms)"
        },
        "kiroSdlc.backend.chatTimeout": {
          "type": "number",
          "default": 120000,
          "description": "Timeout for chat responses (ms)"
        },
        "kiroSdlc.backend.healthCheckInterval": {
          "type": "number",
          "default": 30000,
          "description": "Health check interval (ms)"
        },
        "kiroSdlc.mcpServerPort": {
          "type": "number",
          "default": 9181,
          "description": "Local MCP wrapper server port — the in-process HTTP server that the IDE connects to"
        },
        "kiroSdlc.enableMcpServer": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the local MCP wrapper server on startup"
        },
        "kiroSdlc.mcpServerUrl": {
          "type": "string",
          "default": "",
          "description": "Override URL for the local MCP wrapper server (leave empty to use mcpServerPort)"
        },
        "kiroSdlc.configPath": {
          "type": "string",
          "default": ".code-intel/orchestration.json",
          "description": "Path to orchestration config file (relative to workspace root)"
        },
        "kiroSdlc.llmProvider": {
          "type": "string",
          "default": "anthropic",
          "enum": ["anthropic", "openai", "ollama", "lmstudio", "openrouter", "onnx", "kiro"],
          "description": "Active LLM provider"
        },
        "kiroSdlc.llmModel": {
          "type": "string",
          "default": "",
          "description": "Override model for the selected provider"
        },
        "kiroSdlc.anthropicBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Custom base URL for Anthropic API (leave empty for official)"
        },
        "kiroSdlc.openaiBaseUrl": {
          "type": "string",
          "default": "",
          "description": "Custom base URL for OpenAI API"
        },
        "kiroSdlc.ollamaUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama server URL"
        },
        "kiroSdlc.lmstudioBaseUrl": {
          "type": "string",
          "default": "",
          "description": "LM Studio server URL (default: http://localhost:1234/v1)"
        },
        "kiroSdlc.openrouterBaseUrl": {
          "type": "string",
          "default": "",
          "description": "OpenRouter API base URL"
        },
        "kiroSdlc.kiroModel": {
          "type": "string",
          "default": "auto",
          "description": "Kiro gateway model selection"
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "kiroSdlc.injectAll",
          "when": "view == kiroSdlcTree",
          "group": "navigation"
        },
        {
          "command": "kiroSdlc.openSettings",
          "when": "view == kiroSdlcTree",
          "group": "navigation"
        },
        {
          "command": "kiroSdlc.status",
          "when": "view == kiroSdlcTree",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run copy-resources && npm run gen-checksums && npm run esbuild-production",
    "compile": "tsc -p ./",
    "esbuild": "node esbuild.js",
    "esbuild-production": "node esbuild.js --production",
    "esbuild-watch": "node esbuild.js --watch",
    "watch": "tsc -watch -p ./",
    "copy-resources": "node scripts/copy-resources.js",
    "gen-checksums": "node scripts/gen-checksums.js",
    "package": "vsce package --no-dependencies",
    "test": "mocha",
    "test:watch": "mocha --watch"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.0.0",
    "@types/sinon": "^17.0.3",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.24.0",
    "esbuild": "^0.21.0",
    "glob": "^13.0.6",
    "mocha": "^10.7.3",
    "sinon": "^17.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "uuid": "^14.0.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@langchain/core": "^1.2.0",
    "@langchain/langgraph": "^1.4.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "filetomarkdown": "^0.6.9"
  }
}
