<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <!-- Lifelines -->
    <mxCell id="cli" value="OpenCode CLI&#xa;(MCP Client)" style="html=1;shape=umlLifeline;perimeter=umlLifeline;whiteSpace=wrap;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="30" y="40" width="110" height="520" as="geometry"/>
    </mxCell>
    <mxCell id="ws" value="WrapperServer&#xa;(port 9186)" style="html=1;shape=umlLifeline;perimeter=umlLifeline;whiteSpace=wrap;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="280" y="40" width="130" height="520" as="geometry"/>
    </mxCell>
    <mxCell id="back" value="Backend&#xa;REST API" style="html=1;shape=umlLifeline;perimeter=umlLifeline;whiteSpace=wrap;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="580" y="40" width="110" height="520" as="geometry"/>
    </mxCell>
    <!-- tools/list flow -->
    <mxCell id="m1" value="POST /mcp (tools/list)" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=1;exitY=0.1;entryX=0;entryY=0.1;fontSize=11;" edge="1" parent="1" source="cli" target="ws">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="label-list" value="▲ tools/list flow" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fontSize=10;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="120" y="80" width="130" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="m2" value="route to getToolsRewritten()" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=0;exitY=0.2;entryX=1;entryY=0.2;fontSize=11;dashed=1;" edge="1" parent="1" source="cli" target="ws">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m3" value="REST GET /tools" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=1;exitY=0.3;entryX=0;entryY=0.3;fontSize=11;" edge="1" parent="1" source="ws" target="back">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m4" value="tool definitions (JSON)" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=0;exitY=0.35;entryX=1;entryY=0.35;fontSize=11;strokeColor=#82b366;fillColor=#d5e8d4;" edge="1" parent="1" source="back" target="ws">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m5" value="base64Proxy.rewriteSchemasForLlm()" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=0.5;exitY=0.4;entryX=0.5;entryY=0.4;fontSize=11;strokeColor=#9673a6;dashed=1;" edge="1" parent="1" source="ws" target="ws">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m6" value="200 + tool list with proxy" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=0;exitY=0.48;entryX=1;entryY=0.48;fontSize=11;strokeColor=#82b366;fillColor=#d5e8d4;" edge="1" parent="1" source="ws" target="cli">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- tools/call flow -->
    <mxCell id="m7" value="POST /mcp (tools/call)" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=1;exitY=0.6;entryX=0;entryY=0.6;fontSize=11;" edge="1" parent="1" source="cli" target="ws">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="label-call" value="▲ tools/call flow" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fontSize=10;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;" vertex="1" parent="1">
      <mxGeometry x="120" y="300" width="130" height="20" as="geometry"/>
    </mxCell>
    <mxCell id="m8" value="routeToolCall()" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=0;exitY=0.65;entryX=1;entryY=0.65;fontSize=11;dashed=1;" edge="1" parent="1" source="cli" target="ws">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m9" value="REST call tool" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=1;exitY=0.75;entryX=0;entryY=0.75;fontSize=11;" edge="1" parent="1" source="ws" target="back">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m10" value="tool result" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=0;exitY=0.8;entryX=1;entryY=0.8;fontSize=11;strokeColor=#82b366;fillColor=#d5e8d4;" edge="1" parent="1" source="back" target="ws">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m11" value="base64Proxy.proxyOutput()" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=0.5;exitY=0.85;entryX=0.5;entryY=0.85;fontSize=11;strokeColor=#9673a6;dashed=1;" edge="1" parent="1" source="ws" target="ws">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="m12" value="200 + result with proxy" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=0;exitY=0.92;entryX=1;entryY=0.92;fontSize=11;strokeColor=#82b366;fillColor=#d5e8d4;" edge="1" parent="1" source="ws" target="cli">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
