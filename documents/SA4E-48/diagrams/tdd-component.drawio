<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="bg" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="0" y="0" width="800" height="500" as="geometry"/>
    </mxCell>
    <!-- Client -->
    <mxCell id="client" value="OpenCode CLI&#xa;(MCP Client)" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;shadow=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="30" y="180" width="140" height="60" as="geometry"/>
    </mxCell>
    <!-- SSE Connection arrow -->
    <mxCell id="sse-arrow" value="GET /mcp (SSE)&#xa;POST /mcp (JSON-RPC)" style="html=1;verticalAlign=bottom;endArrow=blockThin;exitX=1;exitY=0.3;entryX=0;entryY=0.4;fontSize=11;" edge="1" parent="1" source="client" target="wrapperserver">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- WrapperServer box -->
    <mxCell id="wrapperserver" value="VS Code Extension (port 9186)" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;shadow=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="300" y="40" width="200" height="420" as="geometry"/>
    </mxCell>
    <mxCell id="ws-title" value="WrapperServer" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fillColor=#ffe680;strokeColor=#d6b656;rounded=1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
      <mxGeometry x="310" y="50" width="180" height="30" as="geometry"/>
    </mxCell>
    <!-- Internal components -->
    <mxCell id="handleReq" value="handleRequest()&#xa;CORS + Routing" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="320" y="100" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="handleMcp" value="handleMcp()&#xa;GET / POST Dispatch" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="320" y="160" width="160" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="handleMcpGet" value="handleMcpGet()&#xa;SSE Stream + endpoint&#xa;+ initialized + keep-alive" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="320" y="220" width="160" height="50" as="geometry"/>
    </mxCell>
    <mxCell id="handleMcpPost" value="handleMcpPost()&#xa;JSON-RPC Router&#xa;initialize / ping / tools/list / tools/call" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="320" y="290" width="160" height="50" as="geometry"/>
    </mxCell>
    <!-- Internal arrows -->
    <mxCell id="a1" value="" style="endArrow=blockThin;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=10;" edge="1" parent="1" source="handleReq" target="handleMcp">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="a2" value="GET /mcp" style="endArrow=blockThin;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="handleMcp" target="handleMcpGet">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="a3" value="POST /mcp" style="endArrow=blockThin;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;fontSize=9;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="handleMcp" target="handleMcpPost">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- BEHIND POST handler sub-components -->
    <mxCell id="routeToolCall" value="routeToolCall()&#xa;local vs remote dispatch" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="320" y="360" width="75" height="40" as="geometry"/>
    </mxCell>
    <mxCell id="getTools" value="getToolsRewritten()&#xa;Base64Proxy rewrite" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;rounded=1;fontSize=9;" vertex="1" parent="1">
      <mxGeometry x="405" y="360" width="75" height="40" as="geometry"/>
    </mxCell>
    <!-- Backend REST API -->
    <mxCell id="backend" value="Backend REST API&#xa;(Code Intelligence MCP Server)" style="html=1;verticalAlign=middle;align=center;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;shadow=1;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="600" y="180" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="be-arrow" value="" style="endArrow=blockThin;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;fontSize=10;" edge="1" parent="1" source="wrapperserver" target="backend">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- Legend -->
    <mxCell id="legend" value="Legend:&#xa;🟢 SSE/Stream handling&#xa;🔴 Routing/CORS&#xa;🟣 Tool processing" style="html=1;verticalAlign=top;align=left;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#cccccc;rounded=1;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="30" y="380" width="160" height="60" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
