<mxGraphModel adaptiveColors="auto"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="state-disconnected" value="DISCONNECTED" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#f8cecc;" vertex="1" parent="1"><mxGeometry x="40" y="40" width="160" height="50" as="geometry"/></mxCell><mxCell id="state-sse-connecting" value="SSE CONNECTING&#xa;(GET /mcp)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#fff2cc;" vertex="1" parent="1"><mxGeometry x="40" y="160" width="160" height="50" as="geometry"/></mxCell><mxCell id="state-sse-open" value="SSE OPEN&#xa;(endpoint received)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d5e8d4;" vertex="1" parent="1"><mxGeometry x="40" y="280" width="160" height="50" as="geometry"/></mxCell><mxCell id="state-initialized" value="INITIALIZED&#xa;(handshake done)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#d5e8d4;" vertex="1" parent="1"><mxGeometry x="300" y="280" width="160" height="50" as="geometry"/></mxCell><mxCell id="state-ready" value="READY&#xa;(tools listed)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#b6d7a8;" vertex="1" parent="1"><mxGeometry x="300" y="160" width="160" height="50" as="geometry"/></mxCell><mxCell id="state-error" value="ERROR&#xa;(405 / timeout)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;fillColor=#f8cecc;" vertex="1" parent="1"><mxGeometry x="300" y="40" width="160" height="50" as="geometry"/></mxCell><mxCell id="t-disconnected-sse" value="connect()" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;fontSize=11;" edge="1" parent="1" source="state-disconnected" target="state-sse-connecting"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="t-sse-open" value="200 + event: endpoint" style="edgeStyle=orthogonalEdgeStyle;html=1;rounded=1;fontSize=11;" edge="1" parent="1" source="state-sse-connecting" target="state-sse-open"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="t-init" value="