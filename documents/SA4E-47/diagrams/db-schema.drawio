<mxGraphModel adaptiveColors="auto"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="ke" value="&lt;b&gt;knowledge_entries&lt;/b&gt;&#10;---&#10;id: INTEGER PK&#10;content: TEXT NOT NULL&#10;summary: TEXT NOT NULL&#10;type: TEXT NOT NULL&#10;tier: TEXT NOT NULL&#10;scope: TEXT NOT NULL&#10;tags: TEXT&#10;structured_map: TEXT DEFAULT '{}'  &lt;= SA4E-47&#10;source: TEXT&#10;user_id: TEXT&#10;project_id: TEXT&#10;created_at: TEXT&#10;updated_at: TEXT&#10;confidence: REAL&#10;quality_score: REAL&#10;... (+ more metadata)" style="shape=table;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;arcSize=10;" vertex="1" parent="1"><mxGeometry x="30" y="30" width="300" height="260" as="geometry"/></mxCell><mxCell id="pt" value="&lt;b&gt;pending_tasks&lt;/b&gt;&#10;---&#10;id: INTEGER PK&#10;task_type: TEXT NOT NULL&#10;entry_id: INTEGER FK&#10;status: TEXT NOT NULL&#10;payload: TEXT (JSON)&#10;retry_count: INTEGER&#10;max_retries: INTEGER&#10;error: TEXT&#10;created_at: TEXT&#10;started_at: TEXT&#10;completed_at: TEXT&#10;&#10;FK: entry_id -&gt; knowledge_entries.id" style="shape=table;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;arcSize=10;" vertex="1" parent="1"><mxGeometry x="440" y="30" width="300" height="250" as="geometry"/></mxCell><mxCell id="note" value="&lt;b&gt;SA4E-47 Changes:&lt;/b&gt;&#10;✅ No schema migration needed&#10;✅ structured_map already exists (DEFAULT '{}')&#10;✅ pending_tasks.payload: context field added&#10;✅ No new indexes needed&#10;🔥 FTS5 not affected (structured_map not indexed)" style="text;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;rounded=1;arcSize=10;" vertex="1" parent="1"><mxGeometry x="100" y="320" width="560" height="100" as="geometry"/></mxCell></root></mxGraphModel>