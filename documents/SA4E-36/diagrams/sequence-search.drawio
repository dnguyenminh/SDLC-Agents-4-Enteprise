      </mxGeometry>
    </mxCell>
    <mxCell id="note-calc" value="For each entry:&#10;temporal = pinned ? 1.0 : 0.5^(age/30)&#10;outcome = (S+1)/(S+F+2)&#10;supersede = superseded ? 0.1 : 1.0&#10;composite = fts * temporal * conf * outcome * predict * supersede" style="shape=note;whiteSpace=wrap;html=1;size=14;verticalAlign=top;align=left;spacingLeft=8;fontSize=9;fillColor=#ffffcc;strokeColor=#d6b656;" parent="1" vertex="1">
