        <mxPoint x="550" y="220" as="sourcePoint"/>
        <mxPoint x="340" y="220" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="JOIN knowledge_entries&#10;WHERE expires_at IS NULL OR expires_at >= now&#10;AND archived = 0" style="html=1;verticalAlign=bottom;endArrow=block;fontSize=9;" parent="1" edge="1">
      <mxGeometry relative="1" as="geometry">
