      <mxGeometry relative="1" as="geometry">
        <mxPoint x="390" y="260" as="sourcePoint"/>
        <mxPoint x="390" y="290" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="INSERT INTO entry_outcomes&#10;(entry_id, outcome, agent_name, context)" style="html=1;verticalAlign=bottom;endArrow=block;fontSize=9;" parent="1" edge="1">
