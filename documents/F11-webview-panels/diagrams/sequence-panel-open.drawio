    <mxCell id="ll_mcp" value="MCP Server" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;portConstraint=eastwest;size=16;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="720" y="50" width="100" height="550" as="geometry"/>
    </mxCell>
    <mxCell id="m1" value="openPanel(type)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="110" y="120" as="sourcePoint"/>
        <mxPoint x="280" y="120" as="targetPoint"/>
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="createPanel(type)" style="html=1;endSize=6;fontSize=10;" edge="1" parent="1">
