      <mxGeometry x="360" y="1260" width="120" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;endSize=6;" edge="1" source="start" target="trigger" parent="1">
      <mxGeometry relative="1" as="geometry"/>
