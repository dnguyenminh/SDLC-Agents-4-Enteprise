    </mxCell>
    <mxCell id="render" value="Render HTML&#10;(Iframe / Custom)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="340" y="530" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="load_data" value="loadData()&#10;Fetch from MCP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="340" y="650" width="160" height="70" as="geometry"/>
