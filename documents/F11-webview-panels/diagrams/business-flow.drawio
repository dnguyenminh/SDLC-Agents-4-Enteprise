      <mxGeometry x="340" y="900" width="160" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="show_error" value="Show Error&#10;Overlay + Retry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c62828;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="560" y="780" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="interact" value="User Interacts&#10;(click, filter, edit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="340" y="1020" width="160" height="70" as="geometry"/>
