    </mxCell>
    <mxCell id="reveal" value="Reveal existing&#10;panel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
